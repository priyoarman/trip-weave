# Server Port
PORT=5050

# Database Connection (used by migration and runtime)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trip_weave

# Secret Key for JWT Authentication
JWT_SECRET=your_super_secret_key_here

# Flight search API
DUFFEL_API_URL="https://api.duffel.com"
AVIATION_STACK_KEY=your_aviation_secret_key_here
DUFFEL_TOKEN=your_duffel_secret_key_here

# Groq extraction API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-20b
