generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SenderRole {
  user
  assistant
}

enum ConversationStatus {
  active
  archived
}

model User {
  id                BigInt         @id @default(autoincrement())
  name              String?
  email             String         @unique
  passwordHash      String         @map("password_hash")
  currencyId        Int?           @map("currency_id")
  currency          Currency?      @relation(fields: [currencyId], references: [id], onDelete: SetNull)
  conversations     Conversation[]
  savedOffers       SavedOffer[]

  @@index([currencyId])
  @@map("users")
}

model Currency {
  id          Int         @id @default(autoincrement())
  code        String      @unique @db.VarChar(3)
  name        String
  symbol      String?
  users       User[]
  savedOffers SavedOffer[]

  @@map("currencies")
}

model Conversation {
  id        BigInt             @id @default(autoincrement())
  userId    BigInt             @map("user_id")
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  status    ConversationStatus @default(active)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             BigInt       @id @default(autoincrement())
  conversationId BigInt       @map("conversation_id")
  senderRole     SenderRole   @map("sender_role")
  textContent    String       @map("text_content")
  timestamp      DateTime     @default(now()) @db.Timestamptz(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model SavedOffer {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt   @map("user_id")
  flightNumber  String   @map("flight_number")
  origin        String
  destination   String
  price         Decimal  @map("price") @db.Decimal(10, 2)
  currencyId    Int?     @map("currency_id")
  currency   Currency? @relation(fields: [currencyId], references: [id], onDelete: SetNull)
  departureTime DateTime @map("departure_time") @db.Timestamptz(6)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currencyId])
  @@index([userId])
  @@map("saved_offers")
}