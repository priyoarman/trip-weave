  "bugs": {
    "url": "https://github.com/abikrithika/trip-weave/issues"
  },
  "homepage": "https://github.com/abikrithika/trip-weave#readme",
  "dependencies": {
    "@ai-sdk/groq": "^3.0.41",
    "@prisma/client": "^6.16.2",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^6.16.2"
  }
}