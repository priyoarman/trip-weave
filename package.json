{
  "name": "trip-weave",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "api/src/server.js",
  "scripts": {
    "dev": "nodemon api/src/server.js",
    "start": "node api/src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:generate": "prisma generate --config api/src/db/code/prisma.config.js",
    "db:validate": "prisma validate --config api/src/db/code/prisma.config.js",
    "db:create": "node api/src/db/code/ensureDatabase.js",
    "db:migrate": "prisma migrate dev --config api/src/db/code/prisma.config.js",
    "db:seed": "prisma db seed --config api/src/db/code/prisma.config.js",
    "db:deploy": "prisma migrate deploy --config api/src/db/code/prisma.config.js",
    "db:all": "npm run db:create && npm run db:validate && npm run db:migrate && npm run db:generate && npm run db:seed"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abikrithika/trip-weave.git"
  },
  "keywords": [],
  "author": "",
